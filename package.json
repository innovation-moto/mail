{
  "name": "mail",
  "version": "1.0.0",
  "private": true,
  "main": "dist/electron/main.js",
  "description": "AI-powered personal mail client",
  "scripts": {
    "dev": "concurrently -n \"next,electron\" -c \"cyan,yellow\" \"npm run dev:next\" \"npm run dev:electron\"",
    "dev:next": "cd app && node_modules/.bin/next dev -p 3000",
    "dev:electron": "wait-on http://localhost:3000 && tsc -p tsconfig.electron.json && cross-env NODE_ENV=development electron .",
    "build": "npm run build:next && npm run build:electron",
    "build:next": "cd app && BUILD_FOR_ELECTRON=true node_modules/.bin/next build",
    "build:electron": "tsc -p tsconfig.electron.json",
    "package": "npm run build && electron-builder",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "better-sqlite3": "^12.10.0",
    "date-fns": "^3.6.0",
    "imapflow": "^1.0.169",
    "nodemailer": "^6.9.14",
    "openai": "^6.37.0",
    "postal-mime": "^2.3.0",
    "sanitize-html": "^2.13.0",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^20.14.0",
    "@types/nodemailer": "^6.4.15",
    "@types/sanitize-html": "^2.13.0",
    "@types/uuid": "^10.0.0",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "electron-rebuild": "^3.2.9",
    "typescript": "^5.5.2",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.innovation.mail",
    "productName": "IM Mail",
    "directories": {
      "output": "release",
      "app": "."
    },
    "files": [
      "dist/**/*",
      "node_modules/**/*",
      "package.json",
      "!node_modules/.cache"
    ],
    "mac": {
      "target": "dmg",
      "category": "public.app-category.productivity",
      "icon": "build/icon.icns"
    },
    "win": {
      "target": "nsis"
    },
    "extraResources": [
      {
        "from": "app/out",
        "to": "app/out",
        "filter": [
          "**/*"
        ]
      }
    ]
  }
}
